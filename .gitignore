# Map enrichment snapshots — timestamped raw pulls are big and regeneratable;
# the "latest" aliases (data/overture_buildings.geojson, data/overture_places.geojson)
# and the merged product (data/lanecove_enriched.geojson) are NOT ignored and
# should be committed so that pipeline is reproducible without re-pulling.
data/sources/

# Local AI / tooling caches
.claude/

# Fitness-audit report - regenerated by `make fitness-audit`, not committed
# (snapshot-of-basic-fitness belongs to a point in time, not to source)
data/fitness-report.json

# Multi-day experiment runs - produced by tools/run_multi_day_experiment.py
# per-seed JSON + aggregate; point-in-time artifacts, not source
data/runs/

# Variant-suite experiments - produced by tools/run_variant_suite.py
# per-variant × per-seed × contest + report scaffold; point-in-time
data/experiments/
